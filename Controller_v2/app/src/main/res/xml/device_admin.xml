<?xml version="1.0" encoding="utf-8"?>
<!--
    Declares the device-admin policies this app's DeviceAdminReceiver
    can request. For a kiosk via Device Owner provisioning, the platform
    grants all needed permissions automatically — this file just needs
    to exist and be valid.
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <limit-password />
        <watch-login />
        <reset-password />
        <force-lock />
        <wipe-data />
        <expire-password />
        <encrypted-storage />
        <disable-camera />
        <disable-keyguard-features />
    </uses-policies>
</device-admin>
